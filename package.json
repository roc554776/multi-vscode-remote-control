    "lint": "eslint packages/*/src"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/eslint__js": "^8.42.3",
    "@types/node": "^20.0.0",
    "eslint": "^10.2.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.58.0"
  }
}
